<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="ld90">
    <pose>0 0 0.10 0 0 0</pose>

    <self_collide>false</self_collide>
    <static>false</static>

    <!-- ========================= -->
    <!-- Base principal do robô    -->
    <!-- ========================= -->
    <link name="base_link">
      <inertial>
        <pose>0 0 0.19 0 0 0</pose>
        <mass>90.0</mass>
        <inertia>
          <ixx>5.0</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>8.0</iyy>
          <iyz>0.0</iyz>
          <izz>10.0</izz>
        </inertia>
      </inertial>

      <collision name="base_collision">
        <pose>0 0 0.23 0 0 0</pose>
        <geometry>
          <box>
            <size>0.68 0.48 0.18</size>
          </box>
        </geometry>
      </collision>

      <visual name="base_visual">
        <pose>0 0 0.244 0 0 1.57079632679</pose>
        <geometry>
          <mesh>
            <uri>model://amr_description/meshes/LD90.obj</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
        <material>
          <ambient>0.75 0.75 0.75 1</ambient>
          <diffuse>0.75 0.75 0.75 1</diffuse>
          <specular>0.1 0.1 0.1 1</specular>
        </material>
      </visual>
    </link>

    <!-- ========================= -->
    <!-- Roda esquerda             -->
    <!-- ========================= -->
    <link name="left_wheel">
      <pose>0.0 0.21 0.10 1.57079632679 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.01</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.01</iyy>
          <iyz>0.0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>

      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>3.0</mu>
              <mu2>3.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1000000</lower>
          <upper>1000000</upper>
          <effort>1000000</effort>
          <velocity>1000</velocity>
        </limit>
        <dynamics>
          <friction>0.0</friction>
          <damping>0.1</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- ========================= -->
    <!-- Roda direita              -->
    <!-- ========================= -->
    <link name="right_wheel">
      <pose>0.0 -0.21 0.10 1.57079632679 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.01</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.01</iyy>
          <iyz>0.0</iyz>
          <izz>0.01</izz>
        </inertia>
      </inertial>

      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>3.0</mu>
              <mu2>3.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.05 0.05 0.05 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1000000</lower>
          <upper>1000000</upper>
          <effort>1000000</effort>
          <velocity>1000</velocity>
        </limit>
        <dynamics>
          <friction>0.0</friction>
          <damping>0.1</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- ========================= -->
    <!-- Casters                   -->
    <!-- ========================= -->
    <link name="rear_caster">
      <pose>-0.25 0 0.04 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.001</iyy>
          <iyz>0.0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>

      <collision name="rear_caster_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.01</mu>
              <mu2>0.01</mu2>
              <slip1>1.0</slip1>
              <slip2>1.0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="rear_caster_joint" type="ball">
      <parent>base_link</parent>
      <child>rear_caster</child>
    </joint>

    <link name="front_caster">
      <pose>0.25 0 0.04 0 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.001</iyy>
          <iyz>0.0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>

      <collision name="front_caster_collision">
        <geometry>
          <sphere>
            <radius>0.04</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.01</mu>
              <mu2>0.01</mu2>
              <slip1>1.0</slip1>
              <slip2>1.0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="front_caster_joint" type="ball">
      <parent>base_link</parent>
      <child>front_caster</child>
    </joint>

    <!-- ========================= -->
    <!-- LiDAR                     -->
    <!-- ========================= -->
    <link name="laser_link">
      <pose>0.265 0 0.195 0 0 0</pose>

      <sensor name="front_lidar" type="gpu_lidar">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
        <topic>/scan</topic>

        <lidar>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-2.0943951</min_angle>
              <max_angle>2.0943951</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.05</min>
            <max>20.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
      </sensor>

      <visual name="laser_visual">
        <geometry>
          <cylinder>
            <radius>0.03</radius>
            <length>0.03</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.0 0.0 0.0 1</ambient>
          <diffuse>0.0 0.0 0.0 1</diffuse>
        </material>
      </visual>
    </link>


    <joint name="laser_joint" type="fixed">
      <parent>base_link</parent>
      <child>laser_link</child>
    </joint>

    <!-- ========================= -->
    <!-- Diff Drive                -->
    <!-- ========================= -->
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.42</wheel_separation>
      <wheel_radius>0.10</wheel_radius>

      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>

      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>1.5</max_angular_acceleration>
    </plugin>

    <plugin filename="gz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
      <publish_link_pose>false</publish_link_pose>
      <publish_sensor_pose>false</publish_sensor_pose>
      <publish_collision_pose>false</publish_collision_pose>
      <publish_visual_pose>false</publish_visual_pose>

      <publish_model_pose>true</publish_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_publisher>false</static_publisher>
      <static_update_frequency>1</static_update_frequency>
    </plugin>

  </model>
</sdf>